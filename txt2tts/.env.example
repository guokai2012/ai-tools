# .env.example —— 复制为 .env 并填入实际值；切勿提交 .env
#
# pydantic-settings 用 __（双下划线）表示嵌套：
#   APP__* 应用层 / LLM__* MiniMax M3 / MINIMAX__* MiniMax speech-2.8-hd TTS / EDGE__* edge-tts 备选

# ====== 应用层（APP__*） ======
APP__HOST=0.0.0.0
APP__PORT=8000
APP__OUTPUT_DIR=./outputs
APP__STATIC_DIR=./app/static
APP__LIBRARY_DB_FILENAME=library.db
APP__MAX_MD_SIZE_KB=1024
APP__MAX_NORMALIZED_CHARS=50000

# TTS Provider：minimax（默认，与 M3 同厂商 + 原生字幕） | edge（备选）
APP__TTS_PROVIDER=minimax

# ====== 可选 env 覆盖（覆盖内置常量）======
# 3 个 system prompt：APP__M3_SYSTEM_PROMPT
# / APP__SPLIT_SYSTEM_PROMPT / APP__SEMANTIC_PREPROCESS_PROMPT
# 多行用 \n 转义；SPLIT 必须保留 {max_chars} 占位符
# APP__M3_SYSTEM_PROMPT=自定义的 M3 标准化 prompt
# APP__SPLIT_SYSTEM_PROMPT=自定义的 M3 文档分块 prompt（保留 {max_chars}）
# APP__SEMANTIC_PREPROCESS_PROMPT=自定义的 edge 方案二专用 M3 语义预处理 prompt
#
# 2 个 voice 列表（JSON 数组，每项含 id / name / lang）：
# APP__MINIMAX_VOICES_JSON=[{"id":"male-qn-qingse","name":"青涩青年男声","lang":"zh"}]
# APP__EDGE_VOICES_JSON=[{"id":"zh-CN-XiaoxiaoNeural","name":"晓晓","lang":"zh-CN"}]

# 后台任务看门狗：单个任务停留在同一阶段超过 N 秒自动标记 failed_retryable
# 防止 M3 / TTS 链路 hang 住导致任务永远停在 processing。
APP__TASK_STALL_TIMEOUT_SEC=180.0
APP__TASK_WATCHDOG_INTERVAL_SEC=10.0
APP__TASK_WATCHDOG_ENABLED=true

# ====== MiniMax M3（LLM__*） —— 方案一与方案二都用 ======
LLM__API_KEY=
LLM__BASE_URL=https://api.minimaxi.com/anthropic
LLM__MODEL=MiniMax-M3
LLM__MAX_TOKENS=8192
LLM__TEMPERATURE=0.2
LLM__REQUEST_TIMEOUT_SEC=60.0
LLM__MAX_RETRIES=2

# ====== MiniMax speech-2.8-hd TTS（MINIMAX__*） —— 默认方案（APP__TTS_PROVIDER=minimax） ======
# MINIMAX__API_KEY 留空时回落 LLM__API_KEY（同平台共用密钥体系）。
# 如 TTS 用独立 key：填到 MINIMAX__API_KEY，LLM 仍走 LLM__API_KEY。
MINIMAX__API_KEY=
MINIMAX__BASE_URL=https://api.minimaxi.com
MINIMAX__T2A_PATH=/v1/t2a_v2
MINIMAX__MODEL=speech-2.8-hd
MINIMAX__VOICE_ID=male-qn-qingse
MINIMAX__AUDIO_FORMAT=mp3
MINIMAX__SAMPLE_RATE=32000
MINIMAX__BITRATE=128000
MINIMAX__AUDIO_CHANNEL=1
MINIMAX__SPEED=1.0
MINIMAX__VOL=1.0
MINIMAX__PITCH=0
# v3 起：TTS 情感 / 文本归一化
MINIMAX__VOICE_EMOTION=calm
MINIMAX__VOICE_TEXT_NORMALIZATION=true
# subtitle_type: sentence（句级时间戳）/ word（词级时间戳）
MINIMAX__SUBTITLE_TYPE=sentence
MINIMAX__SUBTITLE_FETCH_TIMEOUT_SEC=15.0
# v3 起：要求响应 audio 字段返回 OSS URL（hex 向后兼容）
MINIMAX__OUTPUT_FORMAT=url
# v4 起：OSS URL 下载重试配置（仅 5xx/429/网络错触发）
MINIMAX__URL_FETCH_TIMEOUT_SEC=60.0
MINIMAX__URL_FETCH_MAX_RETRIES=5
MINIMAX__URL_FETCH_INITIAL_BACKOFF_SEC=1.0
MINIMAX__URL_FETCH_MAX_BACKOFF_SEC=30.0
# T2A 上限
MINIMAX__MAX_INPUT_CHARS_PER_REQUEST=10000
# T2A POST 请求本体（minimax_tts_provider 自身）超时与重试
MINIMAX__REQUEST_TIMEOUT_SEC=180.0
MINIMAX__MAX_RETRIES=2

# ====== edge-tts 备选方案（EDGE__*） —— APP__TTS_PROVIDER=edge 时生效 ======
# 容器里 ffmpeg 已被镜像内置；本地开发用 ./bin/ffmpeg.exe
EDGE__FFMPEG_PATH=/usr/local/bin/ffmpeg
EDGE__FFPROBE_PATH=/usr/local/bin/ffprobe
EDGE__DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
EDGE__RATE=+0%
EDGE__VOLUME=+0%
EDGE__PITCH=+0Hz
EDGE__MAX_SEGMENT_CHARS=200
EDGE__REQUEST_TIMEOUT_SEC=30.0
# 瞬时网络错误自动重试（DNS/TCP/SSL 抖动 → 指数退避重试 N 次）
EDGE__MAX_RETRIES=3
EDGE__RETRY_BACKOFF_SEC=1.0
# ffmpeg / ffprobe 子进程超时（秒）
EDGE__FFPROBE_TIMEOUT_SEC=10.0
EDGE__FFMPEG_CONCAT_TIMEOUT_SEC=120.0
EDGE__MIMO_FFMPEG_CONCAT_TIMEOUT_SEC=600.0