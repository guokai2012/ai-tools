# .env.example —— 复制为 .env 并填入实际值；切勿提交 .env
#
# pydantic-settings 用 __（双下划线）表示嵌套：
#   APP__* 应用层 / LLM__* MiniMax M3 / TTS__* 小米 MiMo / EDGE__* edge-tts 方案二

# ====== 应用层（APP__*） ======
APP__HOST=0.0.0.0
APP__PORT=8000
APP__OUTPUT_DIR=./outputs
APP__STATIC_DIR=./app/static
APP__LIBRARY_DB_FILENAME=library.db
APP__MAX_MD_SIZE_KB=1024
APP__MAX_NORMALIZED_CHARS=50000

# TTS Provider：mimo（原方案） | edge（新方案，免费但需 ffmpeg）
APP__TTS_PROVIDER=mimo

# ====== 可选 env 覆盖（覆盖内置常量）======
# 4 个 system prompt：APP__M3_SYSTEM_PROMPT / APP__LYRICS_SYSTEM_PROMPT
# / APP__SPLIT_SYSTEM_PROMPT / APP__SEMANTIC_PREPROCESS_PROMPT
# 多行用 \n 转义；SPLIT 必须保留 {max_chars} 占位符
# APP__M3_SYSTEM_PROMPT=自定义的 M3 标准化 prompt
# APP__LYRICS_SYSTEM_PROMPT=自定义的 M3 歌词生成 prompt
# APP__SPLIT_SYSTEM_PROMPT=自定义的 M3 文档分块 prompt（保留 {max_chars}）
# APP__SEMANTIC_PREPROCESS_PROMPT=自定义的 edge 方案二专用 M3 语义预处理 prompt
#
# 2 个 voice 列表（JSON 数组，每项含 id / name / lang）：
# APP__MIMO_VOICES_JSON=[{"id":"mimo_default","name":"默认女声","lang":"zh"}]
# APP__EDGE_VOICES_JSON=[{"id":"zh-CN-XiaoxiaoNeural","name":"晓晓","lang":"zh-CN"}]

# 后台任务看门狗：单个任务停留在同一阶段超过 N 秒自动标记 failed_retryable
# 防止 M3 / TTS 链路 hang 住导致任务永远停在 processing。
APP__TASK_STALL_TIMEOUT_SEC=180.0
APP__TASK_WATCHDOG_INTERVAL_SEC=10.0
APP__TASK_WATCHDOG_ENABLED=true

# ====== MiniMax M3（LLM__*） —— 方案一与方案二都用 ======
LLM__API_KEY=
LLM__BASE_URL=https://api.minimaxi.com/anthropic
LLM__MODEL=MiniMax-M3
LLM__MAX_TOKENS=8192
LLM__TEMPERATURE=0.2
LLM__REQUEST_TIMEOUT_SEC=60.0
LLM__MAX_RETRIES=2

# ====== 小米 MiMo TTS（TTS__*） —— 仅方案一 ======
TTS__API_KEY=
TTS__BASE_URL=https://api.xiaomimimo.com
TTS__CHAT_PATH=/v1/chat/completions
TTS__MODEL=mimo-v2.5-tts
TTS__VOICE=mimo_default
TTS__AUDIO_FORMAT=mp3
TTS__TEMPERATURE=0.6
TTS__REQUEST_TIMEOUT_SEC=90.0
TTS__MAX_RETRIES=2

# ====== edge-tts 方案二（EDGE__*） —— APP__TTS_PROVIDER=edge 时生效 ======
# 容器里 ffmpeg 已被镜像内置；本地开发用 ./bin/ffmpeg.exe
EDGE__FFMPEG_PATH=/usr/local/bin/ffmpeg
EDGE__FFPROBE_PATH=/usr/local/bin/ffprobe
EDGE__DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
EDGE__RATE=+0%
EDGE__VOLUME=+0%
EDGE__PITCH=+0Hz
EDGE__MAX_SEGMENT_CHARS=200
EDGE__REQUEST_TIMEOUT_SEC=30.0
# 瞬时网络错误自动重试（DNS/TCP/SSL 抖动 → 指数退避重试 N 次）
EDGE__MAX_RETRIES=3
EDGE__RETRY_BACKOFF_SEC=1.0
# ffmpeg / ffprobe 子进程超时（秒）
EDGE__FFPROBE_TIMEOUT_SEC=10.0
EDGE__FFMPEG_CONCAT_TIMEOUT_SEC=120.0
EDGE__MIMO_FFMPEG_CONCAT_TIMEOUT_SEC=600.0