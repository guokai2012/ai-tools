# .dockerignore —— 减少镜像体积与构建时间

# 版本控制
.git/
.gitignore
.gitattributes

# Python 缓存与虚拟环境
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 项目级产物与本地数据（运行时由卷挂载）
outputs/
bin/

# 截图与本地调试产物
screenshots/
tests/screenshots/

# 测试覆盖报告与 CI
.coverage
.coverage.*
htmlcov/
.tox/
.cache

# 编辑器与系统
.idea/
.vscode/
.DS_Store
Thumbs.db

# 环境与密钥（绝不打进镜像；通过 docker-compose 注入）
.env
.env.local
*.pem
*.key
secrets/

# Docker 自身（避免循环）
Dockerfile
docker-compose.yml
.dockerignore

# AGENTS.md / 文档（保留 README.md 用于镜像内展示）
AGENTS.md
docs/